@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qb: <http://www.semanticweb.org/quickbooks/ontology#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

# Class Definitions
qb:UserTransactionType a owl:Class ;
    rdfs:subClassOf owl:Thing ;
    rdfs:label "User Transaction Type" ;
    rdfs:comment "Base class for all QuickBooks transaction types" .

qb:BankTransactions a owl:Class ;
    rdfs:subClassOf qb:UserTransactionType ;
    rdfs:label "Bank_Transactions" ;
    rdfs:comment "A bank_transactions transaction in QuickBooks" .

qb:Receipts a owl:Class ;
    rdfs:subClassOf qb:UserTransactionType ;
    rdfs:label "Receipts" ;
    rdfs:comment "Inventory receipts and deliveries" .

qb:RecurringTransactions a owl:Class ;
    rdfs:subClassOf qb:UserTransactionType ;
    rdfs:label "Recurring_Transactions" ;
    rdfs:comment "A recurring_transactions transaction in QuickBooks" .

qb:ChartOfAccounts a owl:Class ;
    rdfs:subClassOf qb:UserTransactionType ;
    rdfs:label "Chart of Accounts" ;
    rdfs:comment "Account structure and management" .

qb:BillPayments a owl:Class ;
    rdfs:subClassOf qb:UserTransactionType ;
    rdfs:label "Bill_Payments" ;
    rdfs:comment "A bill_payments transaction in QuickBooks" .

qb:Bills a owl:Class ;
    rdfs:subClassOf qb:UserTransactionType ;
    rdfs:label "Bills" ;
    rdfs:comment "A bills transaction in QuickBooks" .

qb:Contractors a owl:Class ;
    rdfs:subClassOf qb:UserTransactionType ;
    rdfs:label "Contractors" ;
    rdfs:comment "Independent contractor management" .

qb:Expenses a owl:Class ;
    rdfs:subClassOf qb:UserTransactionType ;
    rdfs:label "Expenses" ;
    rdfs:comment "A expenses transaction in QuickBooks" .

qb:Mileage a owl:Class ;
    rdfs:subClassOf qb:UserTransactionType ;
    rdfs:label "Mileage" ;
    rdfs:comment "A mileage transaction in QuickBooks" .

qb:Vendors a owl:Class ;
    rdfs:subClassOf qb:UserTransactionType ;
    rdfs:label "Vendors" ;
    rdfs:comment "A vendors transaction in QuickBooks" .

qb:ExpenseTransaction a owl:Class ;
    rdfs:subClassOf qb:UserTransactionType ;
    rdfs:label "Expense Transaction" ;
    rdfs:comment "Individual business expense transactions" .

qb:Customers a owl:Class ;
    rdfs:subClassOf qb:UserTransactionType ;
    rdfs:label "Customers" ;
    rdfs:comment "Customer management and information" .

qb:Invoices a owl:Class ;
    rdfs:subClassOf qb:UserTransactionType ;
    rdfs:label "Invoices" ;
    rdfs:comment "Customer invoices and billing" .

qb:ProductsandServices a owl:Class ;
    rdfs:subClassOf qb:UserTransactionType ;
    rdfs:label "Products_and_Services" ;
    rdfs:comment "A products_and_services transaction in QuickBooks" .

qb:Salestransactions a owl:Class ;
    rdfs:subClassOf qb:UserTransactionType ;
    rdfs:label "Sales_transactions" ;
    rdfs:comment "A sales_transactions transaction in QuickBooks" .

qb:CreditCardTransactions a owl:Class ;
    rdfs:subClassOf qb:UserTransactionType ;
    rdfs:label "Credit Card Transactions" ;
    rdfs:comment "Credit card purchases and payments" .

qb:ExpensesandBills a owl:Class ;
    rdfs:subClassOf qb:UserTransactionType ;
    rdfs:label "Expenses_and_Bills" ;
    rdfs:comment "A expenses_and_bills transaction in QuickBooks" .

qb:SalesandCustomers a owl:Class ;
    rdfs:subClassOf qb:UserTransactionType ;
    rdfs:label "Sales_and_Customers" ;
    rdfs:comment "A sales_and_customers transaction in QuickBooks" .

qb:Accounting a owl:Class ;
    rdfs:subClassOf qb:UserTransactionType ;
    rdfs:label "Accounting" ;
    rdfs:comment "Transaction types related to general accounting" .

qb:Banking a owl:Class ;
    rdfs:subClassOf qb:UserTransactionType ;
    rdfs:label "Banking" ;
    rdfs:comment "General banking transactions" .

qb:Inventory a owl:Class ;
    rdfs:subClassOf qb:UserTransactionType ;
    rdfs:label "Inventory" ;
    rdfs:comment "Transaction types related to inventory management" .

qb:Payroll a owl:Class ;
    rdfs:subClassOf qb:UserTransactionType ;
    rdfs:label "Payroll" ;
    rdfs:comment "Transaction types related to employee payroll" .

qb:SalesAndCustomers a owl:Class ;
    rdfs:subClassOf qb:UserTransactionType ;
    rdfs:label "Sales and Customers" ;
    rdfs:comment "Transaction types related to sales and customer management" .

qb:BankDeposits a owl:Class ;
    rdfs:subClassOf qb:UserTransactionType ;
    rdfs:label "Bank Deposits" ;
    rdfs:comment "Bank deposit transactions" .

qb:BankReconciliation a owl:Class ;
    rdfs:subClassOf qb:UserTransactionType ;
    rdfs:label "Bank Reconciliation" ;
    rdfs:comment "Bank statement reconciliation" .

qb:BankTransfers a owl:Class ;
    rdfs:subClassOf qb:UserTransactionType ;
    rdfs:label "Bank Transfers" ;
    rdfs:comment "Transfers between bank accounts" .

qb:CustomerPayments a owl:Class ;
    rdfs:subClassOf qb:UserTransactionType ;
    rdfs:label "Customer Payments" ;
    rdfs:comment "Payments received from customers" .

qb:Estimates a owl:Class ;
    rdfs:subClassOf qb:UserTransactionType ;
    rdfs:label "Estimates" ;
    rdfs:comment "Customer estimates and quotes" .

qb:Refunds a owl:Class ;
    rdfs:subClassOf qb:UserTransactionType ;
    rdfs:label "Refunds" ;
    rdfs:comment "Customer refunds and returns" .

qb:SalesReceipts a owl:Class ;
    rdfs:subClassOf qb:UserTransactionType ;
    rdfs:label "Sales Receipts" ;
    rdfs:comment "Point-of-sale sales receipts" .

qb:EmployeeBenefits a owl:Class ;
    rdfs:subClassOf qb:UserTransactionType ;
    rdfs:label "Employee Benefits" ;
    rdfs:comment "Employee benefits and deductions" .

qb:EmployeePayroll a owl:Class ;
    rdfs:subClassOf qb:UserTransactionType ;
    rdfs:label "Employee Payroll" ;
    rdfs:comment "Employee salary and wage payments" .

qb:PayrollTaxes a owl:Class ;
    rdfs:subClassOf qb:UserTransactionType ;
    rdfs:label "Payroll Taxes" ;
    rdfs:comment "Payroll tax calculations and payments" .

qb:InventoryAdjustments a owl:Class ;
    rdfs:subClassOf qb:UserTransactionType ;
    rdfs:label "Inventory Adjustments" ;
    rdfs:comment "Inventory quantity and value adjustments" .

qb:Products a owl:Class ;
    rdfs:subClassOf qb:UserTransactionType ;
    rdfs:label "Products" ;
    rdfs:comment "Product and service management" .

qb:PurchaseOrders a owl:Class ;
    rdfs:subClassOf qb:UserTransactionType ;
    rdfs:label "Purchase Orders" ;
    rdfs:comment "Purchase orders for inventory" .

# Property Definitions
qb:hasName a owl:DatatypeProperty ;
    rdfs:label "Name" ;
    rdfs:comment "Name of the entity" .

qb:hasCompanyName a owl:DatatypeProperty ;
    rdfs:label "CompanyName" ;
    rdfs:comment "Company name" .

qb:hasEmail a owl:DatatypeProperty ;
    rdfs:label "Email" ;
    rdfs:comment "Email address" .

qb:hasPhone a owl:DatatypeProperty ;
    rdfs:label "Phone" ;
    rdfs:comment "Phone number" .

qb:isActive a owl:DatatypeProperty ;
    rdfs:label "Active" ;
    rdfs:comment "Active status" .

qb:hasDocNumber a owl:DatatypeProperty ;
    rdfs:label "DocNumber" ;
    rdfs:comment "Document number" .

qb:hasTotalAmount a owl:DatatypeProperty ;
    rdfs:label "TotalAmount" ;
    rdfs:comment "Total amount" .

qb:hasBalance a owl:DatatypeProperty ;
    rdfs:label "Balance" ;
    rdfs:comment "Balance amount" .

qb:hasTransactionDate a owl:DatatypeProperty ;
    rdfs:label "TransactionDate" ;
    rdfs:comment "Transaction date" .

qb:hasVendorType a owl:DatatypeProperty ;
    rdfs:label "VendorType" ;
    rdfs:comment "Type of vendor" .

qb:hasGivenName a owl:DatatypeProperty ;
    rdfs:label "GivenName" ;
    rdfs:comment "First name" .

qb:hasFamilyName a owl:DatatypeProperty ;
    rdfs:label "FamilyName" ;
    rdfs:comment "Last name" .

qb:hasPaymentMethod a owl:DatatypeProperty ;
    rdfs:label "PaymentMethod" ;
    rdfs:comment "Payment method" .

qb:hasUnappliedAmount a owl:DatatypeProperty ;
    rdfs:label "UnappliedAmount" ;
    rdfs:comment "Unapplied amount" .

qb:hasHours a owl:DatatypeProperty ;
    rdfs:label "Hours" ;
    rdfs:comment "Hours worked" .

qb:hasMinutes a owl:DatatypeProperty ;
    rdfs:label "Minutes" ;
    rdfs:comment "Minutes worked" .

qb:hasHourlyRate a owl:DatatypeProperty ;
    rdfs:label "HourlyRate" ;
    rdfs:comment "Hourly rate" .

qb:hasBillableStatus a owl:DatatypeProperty ;
    rdfs:label "BillableStatus" ;
    rdfs:comment "Billable status" .

qb:hasDescription a owl:DatatypeProperty ;
    rdfs:label "Description" ;
    rdfs:comment "Activity description" .

qb:riskLevel a owl:DatatypeProperty ;
    rdfs:label "RiskLevel" ;
    rdfs:comment "Risk level for fraud detection" .

qb:transactionFrequency a owl:DatatypeProperty ;
    rdfs:label "TransactionFrequency" ;
    rdfs:comment "Typical frequency of this transaction type" .

