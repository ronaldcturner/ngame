 ] .

#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/quickbooks/ontology#belongsToCluster
qbo:belongsToCluster rdf:type owl:ObjectProperty ;
                     rdfs:domain qbo:UserTransactionType ;
                     rdfs:range qbo:UserTransactionType ;
                     rdfs:comment "Indicates which cluster a transaction type belongs to" ;
                     rdfs:label "belongs to cluster" .


#################################################################
#    Data properties
#################################################################

###  http://www.semanticweb.org/quickbooks/ontology#riskLevel
qbo:riskLevel rdf:type owl:DatatypeProperty ;
              rdfs:domain qbo:UserTransactionType ;
              rdfs:range xsd:string ;
              rdfs:comment "Risk level for fraud detection (Low, Medium, High, Critical)" ;
              rdfs:label "risk level" .


###  http://www.semanticweb.org/quickbooks/ontology#transactionFrequency
qbo:transactionFrequency rdf:type owl:DatatypeProperty ;
                         rdfs:domain qbo:UserTransactionType ;
                         rdfs:range xsd:integer ;
                         rdfs:comment "Typical frequency of this transaction type" ;
                         rdfs:label "transaction frequency" .


